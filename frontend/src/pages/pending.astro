---
// src/pages/pending.astro
// Responsabilidad única: informar al usuario que su solicitud está pendiente

import { API_ROUTES } from '@/config/api';

const AUTH_API_URL = import.meta.env.PUBLIC_AUTH_API_URL;
const ROUTE_LOGOUT = API_ROUTES.AUTH.LOGOUT;
const ROUTE_LOGIN  = '/login';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Solicitud enviada — CoreAppointment</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #09090b;
      --surface: #111114;
      --border: #222227;
      --text: #e8eaf0;
      --muted: #4a4b55;
      --muted-2: #6b6c78;
      --accent: #4a6cf7;
      --pending: #f59e0b;
      --pending-bg: rgba(245,158,11,0.07);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    .bg-grid {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(74,108,247,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(74,108,247,0.04) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    }

    .card {
      position: relative;
      z-index: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2.75rem 2.25rem;
      width: 100%;
      max-width: 420px;
      text-align: center;
      box-shadow: 0 40px 100px rgba(0,0,0,0.7);
      animation: appear 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
    }

    @keyframes appear {
      from { opacity: 0; transform: translateY(20px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    .icon-wrapper {
      width: 64px; height: 64px;
      background: var(--pending-bg);
      border: 1px solid rgba(245,158,11,0.2);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }

    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 0.75rem;
    }

    .subtitle {
      font-size: 14px;
      color: var(--muted-2);
      line-height: 1.6;
      margin-bottom: 2rem;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--pending-bg);
      border: 1px solid rgba(245,158,11,0.2);
      border-radius: 999px;
      padding: 6px 14px;
      font-size: 12.5px;
      color: var(--pending);
      font-weight: 500;
      margin-bottom: 2rem;
    }

    .pulse {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--pending);
      animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.5; transform: scale(0.85); }
    }

    .info-box {
      background: #18181c;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      font-size: 13px;
      color: var(--muted-2);
      line-height: 1.6;
      margin-bottom: 1.75rem;
      text-align: left;
    }

    .info-box strong { color: var(--text); font-weight: 500; }

    .btn-retry {
      width: 100%;
      background: var(--accent);
      border: none;
      border-radius: 12px;
      color: #fff;
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      padding: 11px 20px;
      cursor: pointer;
      transition: opacity 0.15s;
      margin-bottom: 0.75rem;
    }

    .btn-retry:hover { opacity: 0.85; }

    .btn-logout {
      width: 100%;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--muted-2);
      font-family: inherit;
      font-size: 14px;
      font-weight: 500;
      padding: 11px 20px;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }

    .btn-logout:hover { background: #18181c; color: var(--text); }
  </style>
</head>
<body>
  <div class="bg-grid"></div>

  <div class="card">
    <div class="icon-wrapper">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" color="#f59e0b">
        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
        <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>

    <h1>Solicitud enviada</h1>
    <p class="subtitle">
      Tu cuenta ha sido registrada correctamente.<br/>
      El equipo de soporte revisará tu solicitud y te asignará los permisos de acceso.
    </p>

    <div class="status-badge">
      <span class="pulse"></span>
      Pendiente de aprobación
    </div>

    <div class="info-box">
      <strong>¿Qué pasa ahora?</strong><br/>
      El equipo el RincondelHarco.com ha recibido tu solicitud.
      Una vez aprobada, podrás acceder al panel automáticamente.
      No necesitas hacer nada más.
    </div>

    <!-- ✅ El usuario intenta ingresar manualmente cuando soporte le avise -->
    <button class="btn-retry" id="btn-retry">
      Ya fui aprobado — intentar ingresar
    </button>

    <button class="btn-logout" id="btn-logout">
      Cerrar sesión
    </button>
  </div>

  <!-- ✅ Sin polling, sin SSE, sin llamadas a la BD -->
  <script define:vars={{ AUTH_API_URL, ROUTE_LOGOUT, ROUTE_LOGIN }}>

    document.getElementById('btn-retry').addEventListener('click', () => {
      window.location.href = ROUTE_LOGIN;
    });

    document.getElementById('btn-logout').addEventListener('click', async () => {
      await fetch(`${AUTH_API_URL}${ROUTE_LOGOUT}`, {
        method: 'POST',
        credentials: 'include',
      });
      window.location.href = ROUTE_LOGIN;
    });

  </script>
</body>
</html>